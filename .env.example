# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional backend proxy URL (recommended for production key security)
VITE_BACKEND_URL=http://localhost:8787

# Weather API (OpenWeatherMap)
VITE_OPENWEATHER_API_KEY=your_openweather_key
OPENWEATHER_API_KEY=your_openweather_key

# Google Routes API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# News API
VITE_NEWS_API_KEY=your_newsapi_key
NEWS_API_KEY=your_newsapi_key

# Backend webhook and ingestion settings
WEBHOOK_SECRET=choose_a_very_long_random_secret_32_plus_chars
FIREBASE_SERVICE_ACCOUNT_PATH=backend/service-account.json
# Optional alternatives:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_APPLICATION_CREDENTIALS=C:/secure/firebase-admin.json

# Optional for sender test scripts
WEBHOOK_URL=http://localhost:8787
