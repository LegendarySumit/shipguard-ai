PORT=8787
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENWEATHER_API_KEY=
NEWS_API_KEY=
# Use at least 32 chars
WEBHOOK_SECRET=

# Firebase Admin credential options (choose one method):
# 1) Path to service account JSON (relative to project root or absolute path)
FIREBASE_SERVICE_ACCOUNT_PATH=

# 2) Raw JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 3) Base64-encoded service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# 4) Discrete env vars
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 5) Application default credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=C:/secure/firebase-admin.json

# Optional webhook base URL
# WEBHOOK_URL=http://localhost:8787
