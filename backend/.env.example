PORT=8787
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OPENWEATHER_API_KEY=
NEWS_API_KEY=
# Use at least 32 chars
WEBHOOK_SECRET=
# Phase 1 hardening flags
# If true, requires X-Webhook-Signature HMAC header on /api/webhooks/shipments
WEBHOOK_REQUIRE_HMAC=false
# If true, allows legacy x-webhook-secret / Bearer token fallback while migrating
WEBHOOK_ALLOW_LEGACY_SECRET=true
# Max accepted clock skew for signed webhook requests
WEBHOOK_TIMESTAMP_TOLERANCE_SEC=300

# Rate limiting
API_RATE_LIMIT_PER_MINUTE=300
WEBHOOK_RATE_LIMIT_PER_MINUTE=120

# PII encryption (required for GDPR-safe storage of customer/product fields)
# Use a strong random key. Supports either raw passphrase or base64-encoded 32-byte key.
PII_ENCRYPTION_KEY=

# Webhook retry queue (prevents ingestion data loss on transient Firestore failures)
WEBHOOK_RETRY_ENABLED=true
WEBHOOK_RETRY_INTERVAL_SEC=60
WEBHOOK_RETRY_MAX_ATTEMPTS=6
WEBHOOK_RETRY_BATCH_SIZE=25

# Firestore retention policy
RETENTION_ENABLED=true
RETENTION_DAYS=365
RETENTION_RUN_EVERY_HOURS=24

# Firebase Admin credential options (choose one method):
# 1) Path to service account JSON (relative to project root or absolute path)
FIREBASE_SERVICE_ACCOUNT_PATH=

# 2) Raw JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# 3) Base64-encoded service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# 4) Discrete env vars
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 5) Application default credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=C:/secure/firebase-admin.json

# Optional webhook base URL
# WEBHOOK_URL=http://localhost:8787
